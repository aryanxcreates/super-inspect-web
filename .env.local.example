# Database (Supabase connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase (auth only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Polar (server: "sandbox" for testing, "production" for live)
POLAR_SERVER=sandbox
POLAR_ORGANIZATION_ID=...
POLAR_ACCESS_TOKEN=polar_pat_...
POLAR_WEBHOOK_SECRET=...
NEXT_PUBLIC_POLAR_SUBSCRIPTION_PRODUCT_ID=...
NEXT_PUBLIC_POLAR_LIFETIME_PRODUCT_ID=...
NEXT_PUBLIC_POLAR_TRIAL_PRODUCT_ID=...

# JWT (for extension auth tokens)
JWT_SECRET=your-jwt-secret-at-least-32-chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Search Console HTML tag verification value
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...
