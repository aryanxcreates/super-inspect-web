generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                   String     @id @db.Uuid
  email                String?
  plan                 String     @default("free")
  polarCustomerId      String?    @map("polar_customer_id")
  polarProductId       String?    @map("polar_product_id")
  licenseKey           String?    @map("license_key")
  trialEndsAt          DateTime?  @map("trial_ends_at") @db.Timestamptz
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  usageLogs UsageLog[]

  @@index([licenseKey], name: "idx_profiles_license_key")
  @@map("profiles")
}

model UsageLog {
  id        BigInt   @id @default(autoincrement())
  userId    String   @map("user_id") @db.Uuid
  feature   String
  action    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, feature, createdAt], name: "idx_usage_logs_user_feature")
  @@map("usage_logs")
}
